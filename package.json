{
  "name": "ai-self-healing-framework",
  "version": "1.0.0",
  "description": "Self-healing test automation framework with AI/LLM support",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "check:locators": "npx tsx framework/utils/locatorHealthChecker.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "install:playwright": "playwright install"
  },
  "keywords": [
    "playwright",
    "self-healing",
    "automation",
    "testing",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.14.0",
    "@types/string-similarity": "^4.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@faker-js/faker": "^9.4.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "openai": "^6.36.0",
    "playwright": "^1.45.0",
    "string-similarity": "^4.0.4"
  }
}
